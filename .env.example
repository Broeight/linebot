# ── LINE Messaging API ──────────────────────────────────────
# 從 LINE Developers Console (https://developers.line.biz/) 的
# 「Messaging API」分頁取得
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# ── Groq API（免費）────────────────────────────────────────
# 從 https://console.groq.com/keys 取得（免費、免綁信用卡）
GROQ_API_KEY=your_groq_api_key

# 選用：更換模型（可用清單見 https://console.groq.com/docs/models）
#   預設 llama-3.3-70b-versatile（品質好）
#   想要更快可改成 llama-3.1-8b-instant
# GROQ_MODEL=llama-3.3-70b-versatile

# ── 伺服器 ──────────────────────────────────────────────────
PORT=3000
